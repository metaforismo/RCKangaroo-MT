{
  "name": "jacobian_kangaroo_small",
  "description": "Apple Silicon CPU single-target tiny kangaroo benchmark",
  "build_target": "macos-build",
  "bench_command": [
    "./macos/rck_macos",
    "jacobian-kangaroo-small-bench",
    "--iterations",
    "1",
    "--min-ms",
    "50",
    "--range",
    "8",
    "--jumps",
    "8",
    "--dp-bits",
    "0",
    "--max-steps",
    "4096"
  ],
  "min_improvement_ratio": 0.02
}
